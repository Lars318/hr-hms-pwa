{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["arn1"],
  "functions": {
    "app/api/**": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/alerts",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/morning-brief",
      "schedule": "0 7 * * 1-5"
    }
  ]
}

// HR/HMS PWA – Prisma Schema
// Steg 11A: La til emailSentAt og emailError på Notification

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  HR
  MANAGER
  EMPLOYEE
}

enum ProfileStatus {
  ACTIVE
  INACTIVE
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum DocumentCategory {
  POLICY
  PROCEDURE
  INSTRUCTION
  CHECKLIST
  TEMPLATE
  HMS
  HR
  OTHER
}

enum DocumentVisibility {
  PUBLIC
  PRIVATE
}

enum RiskAssessmentStatus {
  DRAFT
  ACTIVE
  REVIEW
  CLOSED
}

enum RiskItemStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ActionStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum ActionPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ActionSourceType {
  RISK_ITEM
  INCIDENT
  MANUAL
}

enum NotificationType {
  INCIDENT_CREATED
  INCIDENT_ASSIGNED
  INCIDENT_STATUS_CHANGED
  ACTION_ASSIGNED
  ACTION_DUE_SOON
  ACTION_OVERDUE
  DOCUMENT_REQUIRES_READ
  DOCUMENT_EXPIRING
  RISK_REVIEW_DUE
  LEAVE_REQUEST_CREATED
  LEAVE_REQUEST_APPROVED
  LEAVE_REQUEST_REJECTED
  LEAVE_REQUEST_CANCELLED
  HANDBOOK_PUBLISHED
  SYSTEM
}

enum LeaveRequestType {
  VACATION
  SICK_LEAVE
  CARE_LEAVE
  PARENTAL_LEAVE
  UNPAID_LEAVE
  OTHER
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// ─── Modeller ─────────────────────────────────────────────────────────────────

model Location {
  id               String  @id @default(cuid())
  name             String  @unique
  address          String?
  city             String?
  country          String  @default("Norge")
  organizationName String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  safetyRepresentative   Profile? @relation("LocationSafetyRep", fields: [safetyRepresentativeId], references: [id])
  safetyRepresentativeId String?

  hseManager   Profile? @relation("LocationHseManager", fields: [hseManagerId], references: [id])
  hseManagerId String?

  departments      Department[]
  incidents        Incident[]
  riskAssessments  RiskAssessment[]
  actions          Action[]
  leaveRequests    LeaveRequest[]
  profileAssignments ProfileAssignment[]

  @@index([safetyRepresentativeId])
  @@index([hseManagerId])
}

model ProfileAssignment {
  id        String    @id @default(cuid())
  roleLabel String?
  isPrimary Boolean   @default(false)
  startDate DateTime  @default(now())
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId String

  location   Location @relation(fields: [locationId], references: [id])
  locationId String

  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId String?

  @@index([profileId])
  @@index([locationId])
  @@index([departmentId])
}

model Department {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  location   Location? @relation(fields: [locationId], references: [id])
  locationId String?

  employees          Profile[]
  incidents          Incident[]
  riskAssessments    RiskAssessment[]
  actions            Action[]
  leaveRequests      LeaveRequest[]
  profileAssignments ProfileAssignment[]

  @@index([locationId])
}

model Profile {
  id             String        @id @default(cuid())
  supabaseUserId String        @unique
  email          String        @unique
  fullName       String
  title          String?
  phone          String?
  avatarUrl      String?
  role           Role          @default(EMPLOYEE)
  status         ProfileStatus @default(ACTIVE)
  employedAt     DateTime      @default(now())
  terminatedAt   DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId String?

  reportedIncidents    Incident[]                 @relation("IncidentReporter")
  assignedIncidents    Incident[]                 @relation("IncidentAssignee")
  uploadedAttachments  Attachment[]
  ownedDocuments       Document[]
  readConfirmations    DocumentReadConfirmation[]
  ownedAssessments     RiskAssessment[]           @relation("RiskAssessmentOwner")
  responsibleRiskItems RiskItem[]                 @relation("RiskItemResponsible")
  assignedActions      Action[]                   @relation("ActionAssignee")
  notifications        Notification[]
  auditLogs            AuditLog[]
  leaveRequests        LeaveRequest[]       @relation("LeaveRequestEmployee")
  decidedLeaveRequests LeaveRequest[]       @relation("LeaveRequestDecider")
  pushSubscriptions        PushSubscription[]
  publishedHandbookVersions HandbookVersion[]
  handbookAcknowledgements  HandbookAcknowledgement[]
  profileAssignments   ProfileAssignment[]
  safetyRepLocations   Location[]           @relation("LocationSafetyRep")
  hseManagerLocations  Location[]           @relation("LocationHseManager")

  @@index([supabaseUserId])
  @@index([email])
  @@index([status])
}

model Incident {
  id          String           @id @default(cuid())
  title       String
  description String
  severity    IncidentSeverity @default(MEDIUM)
  status      IncidentStatus   @default(OPEN)
  occurredAt  DateTime
  dueDate     DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  reportedBy   Profile @relation("IncidentReporter", fields: [reportedById], references: [id])
  reportedById String

  assignedTo   Profile? @relation("IncidentAssignee", fields: [assignedToId], references: [id])
  assignedToId String?

  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId String?

  location   Location? @relation(fields: [locationId], references: [id])
  locationId String?

  attachments Attachment[]
  auditLogs   AuditLog[]

  @@index([status])
  @@index([severity])
  @@index([reportedById])
  @@index([assignedToId])
  @@index([departmentId])
  @@index([locationId])
}

model Attachment {
  id           String   @id @default(cuid())
  fileName     String
  filePath     String
  mimeType     String
  sizeBytes    Int
  createdAt    DateTime @default(now())

  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  incidentId String

  uploadedBy   Profile @relation(fields: [uploadedById], references: [id])
  uploadedById String

  @@index([incidentId])
  @@index([uploadedById])
  @@index([createdAt])
}

// Selve filen ligger i Supabase Storage (bucket: documents)
model Document {
  id            String             @id @default(cuid())
  title         String
  category      DocumentCategory
  description   String?
  version       Int                @default(1)
  filePath      String             // path i Supabase Storage
  mimeType      String
  sizeBytes     Int
  visibility    DocumentVisibility @default(PUBLIC)
  effectiveFrom DateTime?
  expiresAt     DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  owner   Profile @relation(fields: [ownerId], references: [id])
  ownerId String

  readConfirmations DocumentReadConfirmation[]

  @@index([category])
  @@index([visibility])
  @@index([ownerId])
  @@index([expiresAt])
}

// Én rad per (bruker, dokument, versjon)
model DocumentReadConfirmation {
  id              String   @id @default(cuid())
  documentVersion Int
  confirmedAt     DateTime @default(now())

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId String

  profile   Profile @relation(fields: [profileId], references: [id])
  profileId String

  @@unique([documentId, profileId, documentVersion])
  @@index([documentId])
  @@index([profileId])
}

model RiskAssessment {
  id          String               @id @default(cuid())
  title       String
  description String?
  status      RiskAssessmentStatus @default(DRAFT)
  reviewDate  DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId String?

  location   Location? @relation(fields: [locationId], references: [id])
  locationId String?

  owner   Profile @relation("RiskAssessmentOwner", fields: [ownerId], references: [id])
  ownerId String

  riskItems RiskItem[]

  @@index([status])
  @@index([departmentId])
  @@index([locationId])
  @@index([ownerId])
}

model RiskItem {
  id               String         @id @default(cuid())
  hazard           String
  consequence      String
  likelihood       Int
  impact           Int
  riskScore        Int
  riskLevel        RiskLevel
  existingMeasures String?
  proposedMeasures String?
  status           RiskItemStatus @default(OPEN)
  dueDate          DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  assessment   RiskAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  assessmentId String

  responsible   Profile? @relation("RiskItemResponsible", fields: [responsibleId], references: [id])
  responsibleId String?

  actions Action[]

  @@index([assessmentId])
  @@index([riskLevel])
  @@index([status])
}

model Action {
  id          String         @id @default(cuid())
  title       String
  description String?
  sourceType  ActionSourceType @default(MANUAL)
  sourceId    String?
  priority    ActionPriority @default(MEDIUM)
  status      ActionStatus   @default(OPEN)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  assignedTo   Profile? @relation("ActionAssignee", fields: [assignedToId], references: [id])
  assignedToId String?

  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId String?

  location   Location? @relation(fields: [locationId], references: [id])
  locationId String?

  riskItem   RiskItem? @relation(fields: [riskItemId], references: [id])
  riskItemId String?

  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@index([departmentId])
  @@index([locationId])
  @@index([riskItemId])
  @@index([dueDate])
}

model Notification {
  id           String           @id @default(cuid())
  type         NotificationType
  title        String
  message      String
  linkUrl      String?
  readAt       DateTime?
  emailSentAt  DateTime?
  emailError   String?
  createdAt    DateTime         @default(now())

  recipient   Profile @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  recipientId String

  @@index([recipientId])
  @@index([readAt])
  @@index([createdAt])
  @@index([type])
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  metadata   Json?
  createdAt  DateTime @default(now())

  actor   Profile @relation(fields: [actorId], references: [id])
  actorId String

  incident   Incident? @relation(fields: [incidentId], references: [id])
  incidentId String?

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([incidentId])
}

model LeaveRequest {
  id             String             @id @default(cuid())
  type           LeaveRequestType
  status         LeaveRequestStatus @default(PENDING)
  startDate      DateTime
  endDate        DateTime
  days           Int
  reason         String?
  managerComment String?
  decidedAt      DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  employee   Profile @relation("LeaveRequestEmployee", fields: [employeeId], references: [id])
  employeeId String

  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId String?

  location   Location? @relation(fields: [locationId], references: [id])
  locationId String?

  decidedBy   Profile? @relation("LeaveRequestDecider", fields: [decidedById], references: [id])
  decidedById String?

  @@index([employeeId])
  @@index([departmentId])
  @@index([locationId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

model PushSubscription {
  id         String    @id @default(cuid())
  endpoint   String    @unique
  p256dh     String
  auth       String
  userAgent  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastUsedAt DateTime?
  revokedAt  DateTime?

  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId String

  @@index([profileId])
  @@index([revokedAt])
}

// ─── Personalhåndbok ──────────────────────────────────────────────────────────

model HandbookCategory {
  id          String   @id @default(cuid())
  title       String
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sections HandbookSection[]

  @@index([order])
}

model HandbookSection {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category   HandbookCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId String

  @@index([categoryId])
  @@index([order])
}

model HandbookVersion {
  id          String   @id @default(cuid())
  version     Int
  publishNote String?
  publishedAt DateTime @default(now())

  publishedBy   Profile @relation(fields: [publishedById], references: [id])
  publishedById String

  acknowledgements HandbookAcknowledgement[]

  @@index([version])
  @@index([publishedById])
}

model HandbookAcknowledgement {
  id             String   @id @default(cuid())
  acknowledgedAt DateTime @default(now())

  version   HandbookVersion @relation(fields: [versionId], references: [id])
  versionId String

  profile   Profile @relation(fields: [profileId], references: [id])
  profileId String

  @@unique([versionId, profileId])
  @@index([versionId])
  @@index([profileId])
}

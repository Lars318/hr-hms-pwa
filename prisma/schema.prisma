// HR/HMS PWA – Prisma Schema
// Steg 11A: La til emailSentAt og emailError på Notification

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  HR
  MANAGER
  EMPLOYEE
}

enum ProfileStatus {
  ACTIVE
  INACTIVE
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum DocumentCategory {
  POLICY
  PROCEDURE
  INSTRUCTION
  CHECKLIST
  TEMPLATE
  HMS
  HR
  OTHER
}

enum DocumentVisibility {
  PUBLIC
  PRIVATE
}

enum RiskAssessmentStatus {
  DRAFT
  ACTIVE
  REVIEW
  CLOSED
}

enum RiskItemStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ActionStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum ActionPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ActionSourceType {
  RISK_ITEM
  INCIDENT
  MANUAL
}

enum NotificationType {
  INCIDENT_CREATED
  INCIDENT_ASSIGNED
  INCIDENT_STATUS_CHANGED
  ACTION_ASSIGNED
  ACTION_DUE_SOON
  ACTION_OVERDUE
  DOCUMENT_REQUIRES_READ
  DOCUMENT_EXPIRING
  RISK_REVIEW_DUE
  LEAVE_REQUEST_CREATED
  LEAVE_REQUEST_APPROVED
  LEAVE_REQUEST_REJECTED
  LEAVE_REQUEST_CANCELLED
  HANDBOOK_PUBLISHED
  OVERTIME_SUBMITTED
  OVERTIME_APPROVED
  OVERTIME_REJECTED
  SYSTEM
  WHISTLEBLOWING_RECEIVED
  TRAINING_EXPIRING_SOON
  TRAINING_OVERDUE
  CHEMICAL_REVIEW_DUE
  DATA_REQUEST_RECEIVED
  DATA_REQUEST_COMPLETED
  ONBOARDING_TASK_ASSIGNED
  OFFBOARDING_TASK_ASSIGNED
  ONBOARDING_COMPLETED
  OFFBOARDING_COMPLETED
  REVIEW_SCHEDULED
  REVIEW_COMPLETED
  PERSONNEL_CASE_OPENED
  PERSONNEL_CASE_CLOSED
  COMMENT_ADDED
  CONTRACT_SHARED
  SIGNATURE_REQUESTED
  SIGNATURE_COMPLETED
}

enum OvertimeType {
  OVERTIME       // Utbetalt overtid
  TIME_OFF       // Avspasering
  ON_CALL        // Beredskapsvakt
  TRAVEL_TIME    // Reisetid utenom arbeidstid
}

enum OvertimeStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CANCELLED
}

enum TimeBankAdjustmentReason {
  CORRECTION
  PAYOUT
  RESET
  MANUAL
}

enum AnnouncementTarget {
  ALL
  DEPARTMENT
  LOCATION
}

enum LeaveRequestType {
  VACATION
  SICK_LEAVE
  CARE_LEAVE
  EGENMELDING
  PARENTAL_LEAVE
  UNPAID_LEAVE
  OTHER
}

enum SickLeaveCaseStatus {
  ACTIVE
  CLOSED
}

enum FollowUpStepType {
  OPPFOLGING_PLAN
  DIALOG_MOTE_1
  DIALOG_MOTE_2
  NAV_NOTIFICATION
}

enum SalaryType {
  MONTHLY
  HOURLY
  ANNUAL
}

enum AlertType {
  PROBATION_ENDING
  TRAINING_EXPIRING
  BIRTHDAY
  CONTRACT_EXPIRING
  EGENMELDING_EXTEND
  VERNERUNDE_MISSING
  SUMMER_VACATION_PLAN_REMINDER
  SUMMER_VACATION_MISSING
  INCIDENT_OVERDUE_7D
  INCIDENT_OVERDUE_14D
  INCIDENT_OVERDUE_21D
  FINANCIAL_CONTRACT_NOTICE
  FINANCIAL_CONTRACT_EXP_30
  FINANCIAL_CONTRACT_EXP_60
  FINANCIAL_CONTRACT_EXP_90
  FINANCIAL_CONTRACT_DIGEST
  INTERNKONTROLL_OVERDUE
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// ─── Modeller ─────────────────────────────────────────────────────────────────

model Location {
  id               String  @id @default(cuid())
  name             String  @unique
  address          String?
  city             String?
  country          String  @default("Norge")
  organizationName String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  safetyRepresentative   Profile? @relation("LocationSafetyRep", fields: [safetyRepresentativeId], references: [id])
  safetyRepresentativeId String?

  hseManager   Profile? @relation("LocationHseManager", fields: [hseManagerId], references: [id])
  hseManagerId String?

  departments      Department[]
  incidents        Incident[]
  riskAssessments  RiskAssessment[]
  actions          Action[]
  leaveRequests    LeaveRequest[]
  profileAssignments ProfileAssignment[]
  overtimeEntries  OvertimeEntry[]
  whistleblowingCases WhistleblowingCase[]
  trainingCourses     TrainingCourse[]
  chemicals           Chemical[]
  onboardingTemplates OnboardingTemplate[]
  inspectionRecords   InspectionRecord[]
  financialContracts  FinancialContract[]

  @@index([safetyRepresentativeId])
  @@index([hseManagerId])
}

model ProfileAssignment {
  id        String    @id @default(cuid())
  roleLabel String?
  isPrimary Boolean   @default(false)
  startDate DateTime  @default(now())
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId String

  location   Location @relation(fields: [locationId], references: [id])
  locationId String

  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId String?

  @@index([profileId])
  @@index([locationId])
  @@index([departmentId])
}

model Department {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  location   Location? @relation(fields: [locationId], references: [id])
  locationId String?

  employees          Profile[]
  incidents          Incident[]
  riskAssessments    RiskAssessment[]
  actions            Action[]
  leaveRequests      LeaveRequest[]
  profileAssignments ProfileAssignment[]
  profileDepartments ProfileDepartment[]
  overtimeEntries    OvertimeEntry[]
  whistleblowingCases WhistleblowingCase[]
  chemicals           Chemical[]

  @@index([locationId])
}

// Tilleggsavdelinger for en ansatt (primær ligger på Profile.departmentId).
model ProfileDepartment {
  id           String @id @default(cuid())
  profileId    String
  departmentId String
  createdAt    DateTime @default(now())

  profile    Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([profileId, departmentId])
  @@index([departmentId])
}

model Profile {
  id             String        @id @default(cuid())
  supabaseUserId String        @unique
  email          String        @unique
  fullName       String
  employeeNumber String?
  title          String?
  phone          String?
  avatarUrl      String?
  role           Role          @default(EMPLOYEE)
  status         ProfileStatus @default(ACTIVE)
  employedAt     DateTime      @default(now())
  terminatedAt   DateTime?
  dateOfBirth    DateTime?
  probationEndsAt DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId String?

  // Tilleggsavdelinger (i tillegg til primær department over)
  extraDepartments ProfileDepartment[]

  manager      Profile?  @relation("ProfileManager", fields: [managerId], references: [id])
  managerId    String?
  subordinates Profile[] @relation("ProfileManager")

  reportedIncidents    Incident[]                 @relation("IncidentReporter")
  assignedIncidents    Incident[]                 @relation("IncidentAssignee")
  uploadedAttachments  Attachment[]
  ownedDocuments       Document[]
  linkedDocuments      Document[]  @relation("DocumentLinkedProfile")
  readConfirmations    DocumentReadConfirmation[]
  ownedAssessments     RiskAssessment[]           @relation("RiskAssessmentOwner")
  responsibleRiskItems RiskItem[]                 @relation("RiskItemResponsible")
  assignedActions      Action[]                   @relation("ActionAssignee")
  notifications        Notification[]
  auditLogs            AuditLog[]
  leaveRequests        LeaveRequest[]       @relation("LeaveRequestEmployee")
  decidedLeaveRequests LeaveRequest[]       @relation("LeaveRequestDecider")
  pushSubscriptions        PushSubscription[]
  publishedHandbookVersions HandbookVersion[]
  handbookAcknowledgements  HandbookAcknowledgement[]
  profileAssignments   ProfileAssignment[]
  safetyRepLocations   Location[]           @relation("LocationSafetyRep")
  hseManagerLocations  Location[]           @relation("LocationHseManager")
  overtimeEntries      OvertimeEntry[]
  approvedOvertimeEntries OvertimeEntry[]   @relation("OvertimeApprover")
  timeBankAdjustments  TimeBankAdjustment[] @relation("TimeBankEmployee")
  timeBankAdjustedBy   TimeBankAdjustment[] @relation("TimeBankAdjuster")

  reportedWhistleblowingCases  WhistleblowingCase[]    @relation("WhistleblowingReporter")
  assignedWhistleblowingCases  WhistleblowingCase[]    @relation("WhistleblowingAssignee")
  whistleblowingMessages       WhistleblowingMessage[] @relation("WhistleblowingMessageAuthor")
  whistleblowingAuditLogs      WhistleblowingAuditLog[] @relation("WhistleblowingActor")

  trainingRecords            TrainingRecord[]     @relation("TrainingRecordEmployee")
  registeredTrainingRecords  TrainingRecord[]     @relation("TrainingRecordRegistrar")
  trainingAuditLogs          TrainingAuditLog[]   @relation("TrainingAuditActor")
  createdChemicals           Chemical[]           @relation("ChemicalCreator")
  chemicalAuditLogs          ChemicalAuditLog[]   @relation("ChemicalAuditActor")
  dataSubjectRequests        DataSubjectRequest[] @relation("DataSubjectRequester")
  handledDataRequests        DataSubjectRequest[] @relation("DataSubjectHandler")

  onboardingProcesses        OnboardingProcess[]  @relation("OnboardingEmployee")
  managedOnboardingProcesses OnboardingProcess[]  @relation("OnboardingHr")
  completedOnboardingTasks   OnboardingTask[]     @relation("OnboardingTaskCompleter")
  createdOnboardingTemplates OnboardingTemplate[] @relation("OnboardingTemplateCreator")

  employeeReviews  EmployeeReview[] @relation("ReviewEmployee")
  managerReviews   EmployeeReview[] @relation("ReviewManager")
  createdReviews   EmployeeReview[] @relation("ReviewCreator")

  personnelCases          PersonnelCase[] @relation("PersonnelCaseEmployee")
  managedPersonnelCases   PersonnelCase[] @relation("PersonnelCaseManager")
  createdPersonnelCases   PersonnelCase[] @relation("PersonnelCaseCreator")
  personnelCaseAuditLogs  PersonnelCaseAuditLog[] @relation("PersonnelCaseActor")

  comments Comment[] @relation("CommentAuthor")

  contracts              Contract[]         @relation("ContractEmployee")
  createdContracts       Contract[]         @relation("ContractCreator")
  signatureRequests      SignatureRequest[]  @relation("SignatureRequestSigner")

  inspectionRecords InspectionRecord[] @relation("InspectionPerformedBy")

  announcements           Announcement[]           @relation("AnnouncementAuthor")
  sickLeaveCases          SickLeaveCase[]          @relation("SickLeaveCaseEmployee")
  sickLeaveStepsCompleted SickLeaveFollowUpStep[]   @relation("StepCompletedBy")
  employmentRecords       EmploymentRecord[]        @relation("EmploymentRecordProfile")
  createdEmploymentRecords EmploymentRecord[]       @relation("EmploymentRecordCreator")
  webAuthnCredentials          WebAuthnCredential[]
  internkontrollAnsvar         InternkontrollOmrade[]  @relation("InternkontrollAnsvarlig")
  internkontrollUtfort         InternkontrollLogg[]    @relation("InternkontrollUtfort")
  financialContractsCreated    FinancialContract[]           @relation("FinancialContractCreatedBy")
  financialContractAttachments FinancialContractAttachment[] @relation("FinancialContractAttachmentUploadedBy")

  @@index([supabaseUserId])
  @@index([email])
  @@index([status])
}

model Incident {
  id          String           @id @default(cuid())
  title       String
  description String
  severity    IncidentSeverity @default(MEDIUM)
  status      IncidentStatus   @default(OPEN)
  occurredAt  DateTime
  dueDate     DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  reportedBy   Profile @relation("IncidentReporter", fields: [reportedById], references: [id])
  reportedById String

  assignedTo   Profile? @relation("IncidentAssignee", fields: [assignedToId], references: [id])
  assignedToId String?

  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId String?

  location   Location? @relation(fields: [locationId], references: [id])
  locationId String?

  attachments Attachment[]
  auditLogs   AuditLog[]

  @@index([status])
  @@index([severity])
  @@index([reportedById])
  @@index([assignedToId])
  @@index([departmentId])
  @@index([locationId])
}

model Attachment {
  id           String   @id @default(cuid())
  fileName     String
  filePath     String
  mimeType     String
  sizeBytes    Int
  createdAt    DateTime @default(now())

  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  incidentId String

  uploadedBy   Profile @relation(fields: [uploadedById], references: [id])
  uploadedById String

  @@index([incidentId])
  @@index([uploadedById])
  @@index([createdAt])
}

// Bruker-definerte dokumentkategorier (kan legges til i admin)
model DocumentCategoryLabel {
  id        String     @id @default(cuid())
  name      String
  color     String     @default("#5F5E5A")
  sortOrder Int        @default(0)
  createdAt DateTime   @default(now())

  documents Document[]

  @@index([sortOrder])
}

// Selve filen ligger i Supabase Storage (bucket: documents)
model Document {
  id               String             @id @default(cuid())
  title            String
  category         DocumentCategory
  description      String?
  tags             String[]           @default([])
  version          Int                @default(1)
  filePath         String
  mimeType         String
  sizeBytes        Int
  visibility       DocumentVisibility @default(PUBLIC)
  effectiveFrom    DateTime?
  expiresAt        DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  owner   Profile @relation(fields: [ownerId], references: [id])
  ownerId String

  customCategory   DocumentCategoryLabel? @relation(fields: [customCategoryId], references: [id], onDelete: SetNull)
  customCategoryId String?

  linkedProfile    Profile? @relation("DocumentLinkedProfile", fields: [linkedProfileId], references: [id], onDelete: SetNull)
  linkedProfileId  String?

  readConfirmations DocumentReadConfirmation[]

  @@index([category])
  @@index([customCategoryId])
  @@index([visibility])
  @@index([ownerId])
  @@index([linkedProfileId])
  @@index([expiresAt])
}

// Én rad per (bruker, dokument, versjon)
model DocumentReadConfirmation {
  id              String   @id @default(cuid())
  documentVersion Int
  confirmedAt     DateTime @default(now())

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId String

  profile   Profile @relation(fields: [profileId], references: [id])
  profileId String

  @@unique([documentId, profileId, documentVersion])
  @@index([documentId])
  @@index([profileId])
}

model RiskAssessment {
  id          String               @id @default(cuid())
  title       String
  description String?
  status      RiskAssessmentStatus @default(DRAFT)
  reviewDate  DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId String?

  location   Location? @relation(fields: [locationId], references: [id])
  locationId String?

  owner   Profile @relation("RiskAssessmentOwner", fields: [ownerId], references: [id])
  ownerId String

  riskItems RiskItem[]

  @@index([status])
  @@index([departmentId])
  @@index([locationId])
  @@index([ownerId])
}

model RiskItem {
  id               String         @id @default(cuid())
  hazard           String
  consequence      String
  likelihood       Int
  impact           Int
  riskScore        Int
  riskLevel        RiskLevel
  existingMeasures String?
  proposedMeasures String?
  status           RiskItemStatus @default(OPEN)
  dueDate          DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  assessment   RiskAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  assessmentId String

  responsible   Profile? @relation("RiskItemResponsible", fields: [responsibleId], references: [id])
  responsibleId String?

  actions Action[]

  @@index([assessmentId])
  @@index([riskLevel])
  @@index([status])
}

model Action {
  id          String         @id @default(cuid())
  title       String
  description String?
  sourceType  ActionSourceType @default(MANUAL)
  sourceId    String?
  priority    ActionPriority @default(MEDIUM)
  status      ActionStatus   @default(OPEN)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  assignedTo   Profile? @relation("ActionAssignee", fields: [assignedToId], references: [id])
  assignedToId String?

  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId String?

  location   Location? @relation(fields: [locationId], references: [id])
  locationId String?

  riskItem   RiskItem? @relation(fields: [riskItemId], references: [id])
  riskItemId String?

  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@index([departmentId])
  @@index([locationId])
  @@index([riskItemId])
  @@index([dueDate])
}

model Notification {
  id           String           @id @default(cuid())
  type         NotificationType
  title        String
  message      String
  linkUrl      String?
  readAt       DateTime?
  emailSentAt  DateTime?
  emailError   String?
  createdAt    DateTime         @default(now())

  recipient   Profile @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  recipientId String

  @@index([recipientId])
  @@index([readAt])
  @@index([createdAt])
  @@index([type])
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  metadata   Json?
  createdAt  DateTime @default(now())

  actor   Profile @relation(fields: [actorId], references: [id])
  actorId String

  incident   Incident? @relation(fields: [incidentId], references: [id])
  incidentId String?

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([incidentId])
}

model LeaveRequest {
  id             String             @id @default(cuid())
  type           LeaveRequestType
  status         LeaveRequestStatus @default(PENDING)
  startDate      DateTime
  endDate        DateTime
  days           Int
  reason         String?
  managerComment String?
  decidedAt      DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  employee   Profile @relation("LeaveRequestEmployee", fields: [employeeId], references: [id])
  employeeId String

  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId String?

  location   Location? @relation(fields: [locationId], references: [id])
  locationId String?

  decidedBy   Profile? @relation("LeaveRequestDecider", fields: [decidedById], references: [id])
  decidedById String?

  @@index([employeeId])
  @@index([departmentId])
  @@index([locationId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

model PushSubscription {
  id         String    @id @default(cuid())
  endpoint   String    @unique
  p256dh     String
  auth       String
  userAgent  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastUsedAt DateTime?
  revokedAt  DateTime?

  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId String

  @@index([profileId])
  @@index([revokedAt])
}

// ─── Personalhåndbok ──────────────────────────────────────────────────────────

model HandbookCategory {
  id          String   @id @default(cuid())
  title       String
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sections HandbookSection[]

  @@index([order])
}

model HandbookSection {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category   HandbookCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId String

  @@index([categoryId])
  @@index([order])
}

model HandbookVersion {
  id          String   @id @default(cuid())
  version     Int
  publishNote String?
  publishedAt DateTime @default(now())

  publishedBy   Profile @relation(fields: [publishedById], references: [id])
  publishedById String

  acknowledgements HandbookAcknowledgement[]

  @@index([version])
  @@index([publishedById])
}

model HandbookAcknowledgement {
  id             String   @id @default(cuid())
  acknowledgedAt DateTime @default(now())

  version   HandbookVersion @relation(fields: [versionId], references: [id])
  versionId String

  profile   Profile @relation(fields: [profileId], references: [id])
  profileId String

  @@unique([versionId, profileId])
  @@index([versionId])
  @@index([profileId])
}

// ─── Overtid og timebank ──────────────────────────────────────────────────────

model OvertimeEntry {
  id          String         @id @default(cuid())
  date        DateTime       @db.Date
  hours       Float
  type        OvertimeType
  status      OvertimeStatus @default(DRAFT)
  description String?        @db.Text
  note        String?        // Lederkommentar ved godkjenning/avslag
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  employee   Profile  @relation(fields: [employeeId], references: [id])
  employeeId String

  approvedBy   Profile?  @relation("OvertimeApprover", fields: [approvedById], references: [id])
  approvedById String?
  approvedAt   DateTime?

  location   Location? @relation(fields: [locationId], references: [id])
  locationId String?

  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId String?

  @@index([employeeId])
  @@index([status])
  @@index([date])
  @@index([locationId])
}

model TimeBankAdjustment {
  id        String                   @id @default(cuid())
  hours     Float
  reason    TimeBankAdjustmentReason
  note      String?
  createdAt DateTime                 @default(now())

  employee   Profile @relation("TimeBankEmployee", fields: [employeeId], references: [id])
  employeeId String

  adjustedBy   Profile @relation("TimeBankAdjuster", fields: [adjustedById], references: [id])
  adjustedById String

  @@index([employeeId])
  @@index([createdAt])
}

// ─── Varsling (Whistleblowing) ────────────────────────────────────────────────

enum WhistleblowingCategory {
  HARASSMENT
  DISCRIMINATION
  SAFETY
  FINANCIAL_MISCONDUCT
  ETHICS
  RETALIATION
  OTHER
}

enum WhistleblowingStatus {
  RECEIVED
  UNDER_REVIEW
  INVESTIGATING
  ACTION_REQUIRED
  CLOSED
  REJECTED
}

enum WhistleblowingSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model WhistleblowingCase {
  id             String                  @id @default(cuid())
  caseNumber     String                  @unique
  title          String
  description    String                  @db.Text
  category       WhistleblowingCategory
  status         WhistleblowingStatus    @default(RECEIVED)
  severity       WhistleblowingSeverity  @default(MEDIUM)
  isAnonymous    Boolean                 @default(false)
  isConfidential Boolean                 @default(true)
  receivedAt     DateTime                @default(now())
  closedAt       DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  reporter   Profile? @relation("WhistleblowingReporter", fields: [reporterId], references: [id])
  reporterId String?

  assignedTo   Profile? @relation("WhistleblowingAssignee", fields: [assignedToId], references: [id])
  assignedToId String?

  location   Location? @relation(fields: [locationId], references: [id])
  locationId String?

  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId String?

  messages  WhistleblowingMessage[]
  auditLogs WhistleblowingAuditLog[]

  @@index([status])
  @@index([category])
  @@index([reporterId])
  @@index([assignedToId])
  @@index([locationId])
}

model WhistleblowingMessage {
  id             String   @id @default(cuid())
  body           String   @db.Text
  isInternalNote Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  case   WhistleblowingCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId String

  author   Profile? @relation("WhistleblowingMessageAuthor", fields: [authorId], references: [id])
  authorId String?

  @@index([caseId])
  @@index([authorId])
}

model WhistleblowingAuditLog {
  id        String   @id @default(cuid())
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  case   WhistleblowingCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId String

  actor   Profile? @relation("WhistleblowingActor", fields: [actorId], references: [id])
  actorId String?

  @@index([caseId])
}

// ─── HMS-opplæringsregister ────────────────────────────────────────────────────

enum TrainingStatus {
  ACTIVE
  ARCHIVED
}

model TrainingCourse {
  id             String         @id @default(cuid())
  name           String
  description    String?
  category       String
  isRequired     Boolean        @default(false)
  validityMonths Int?
  status         TrainingStatus @default(ACTIVE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  location   Location? @relation(fields: [locationId], references: [id])
  locationId String?

  records TrainingRecord[]

  @@index([locationId])
  @@index([status])
}

model TrainingRecord {
  id          String    @id @default(cuid())
  completedAt DateTime
  expiresAt   DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  course   TrainingCourse @relation(fields: [courseId], references: [id])
  courseId String

  profile   Profile @relation("TrainingRecordEmployee", fields: [profileId], references: [id])
  profileId String

  registeredBy   Profile @relation("TrainingRecordRegistrar", fields: [registeredById], references: [id])
  registeredById String

  auditLogs TrainingAuditLog[]

  @@unique([courseId, profileId])
  @@index([profileId])
  @@index([courseId])
  @@index([expiresAt])
}

model TrainingAuditLog {
  id        String   @id @default(cuid())
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  record   TrainingRecord? @relation(fields: [recordId], references: [id], onDelete: Cascade)
  recordId String?

  actor   Profile @relation("TrainingAuditActor", fields: [actorId], references: [id])
  actorId String

  @@index([recordId])
}

// ─── Stoffkartotek ─────────────────────────────────────────────────────────────

enum ChemicalStatus {
  ACTIVE
  ARCHIVED
}

model Chemical {
  id                   String         @id @default(cuid())
  name                 String
  supplier             String?
  description          String?
  status               ChemicalStatus @default(ACTIVE)

  // HMS-data
  hazardSymbols        String[]       // f.eks. ["Brannfarlig", "Helseskadelig"]
  protectiveEquipment  String?        // verneutstyr
  riskNote             String?        // kort risikovurdering
  storageInstructions  String?        // oppbevarings­instruksjoner

  // SDS – versjon 1: lenke/referanse (ikke fil­upload)
  sdsReference         String?        // URL eller referansetekst til sikkerhetsdatablad

  // Datoer
  reviewDate           DateTime?      // revisjonsdato
  expiresAt            DateTime?      // utløps-/kontrolldato

  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  location   Location?   @relation(fields: [locationId], references: [id])
  locationId String?

  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId String?

  createdBy   Profile @relation("ChemicalCreator", fields: [createdById], references: [id])
  createdById String

  auditLogs ChemicalAuditLog[]

  @@index([locationId])
  @@index([departmentId])
  @@index([status])
}

model ChemicalAuditLog {
  id        String   @id @default(cuid())
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  chemical   Chemical @relation(fields: [chemicalId], references: [id], onDelete: Cascade)
  chemicalId String

  actor   Profile @relation("ChemicalAuditActor", fields: [actorId], references: [id])
  actorId String

  @@index([chemicalId])
}

// ─── GDPR datainnsyn ──────────────────────────────────────────────────────────

enum DataRequestType {
  ACCESS        // Innsyn (art. 15)
  PORTABILITY   // Dataportabilitet (art. 20)
  RECTIFICATION // Retting (art. 16)
  ERASURE       // Sletting (art. 17)
  OTHER
}

enum DataRequestStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED
}

model DataSubjectRequest {
  id          String            @id @default(cuid())
  type        DataRequestType
  status      DataRequestStatus @default(PENDING)
  message     String?
  adminNote   String?
  completedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  requester   Profile @relation("DataSubjectRequester", fields: [requesterId], references: [id])
  requesterId String

  handledBy   Profile? @relation("DataSubjectHandler", fields: [handledById], references: [id])
  handledById String?

  @@index([requesterId])
  @@index([status])
}

// ─── Onboarding / Offboarding (28A) ──────────────────────────────────────────

enum OnboardingProcessType {
  ONBOARDING
  OFFBOARDING
}

enum OnboardingProcessStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum OnboardingTaskStatus {
  PENDING
  COMPLETED
  SKIPPED
}

model OnboardingTemplate {
  id          String                @id @default(cuid())
  name        String
  description String?
  type        OnboardingProcessType
  isActive    Boolean               @default(true)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  location   Location? @relation(fields: [locationId], references: [id])
  locationId String?

  createdBy   Profile @relation("OnboardingTemplateCreator", fields: [createdById], references: [id])
  createdById String

  tasks     OnboardingTemplateTask[]
  processes OnboardingProcess[]

  @@index([type])
  @@index([locationId])
}

model OnboardingTemplateTask {
  id          String  @id @default(cuid())
  title       String
  description String?
  order       Int     @default(0)
  isRequired  Boolean @default(true)
  daysOffset  Int?    // dager relativt til startdato (positivt = etter, negativt = før)

  template   OnboardingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId String

  @@index([templateId])
}

model OnboardingProcess {
  id          String                  @id @default(cuid())
  type        OnboardingProcessType
  status      OnboardingProcessStatus @default(ACTIVE)
  startDate   DateTime
  completedAt DateTime?
  notes       String?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  employee   Profile @relation("OnboardingEmployee", fields: [employeeId], references: [id])
  employeeId String

  responsibleHr   Profile? @relation("OnboardingHr", fields: [responsibleHrId], references: [id])
  responsibleHrId String?

  template   OnboardingTemplate? @relation(fields: [templateId], references: [id])
  templateId String?

  tasks OnboardingTask[]

  @@index([employeeId])
  @@index([status])
  @@index([type])
}

model OnboardingTask {
  id          String               @id @default(cuid())
  title       String
  description String?
  order       Int                  @default(0)
  isRequired  Boolean              @default(true)
  dueDate     DateTime?
  status      OnboardingTaskStatus @default(PENDING)
  completedAt DateTime?
  notes       String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  process   OnboardingProcess @relation(fields: [processId], references: [id], onDelete: Cascade)
  processId String

  completedBy   Profile? @relation("OnboardingTaskCompleter", fields: [completedById], references: [id])
  completedById String?

  @@index([processId])
  @@index([status])
}

// ─── Medarbeidersamtaler (28B) ────────────────────────────────────────────────

enum ReviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

model EmployeeReview {
  id           String       @id @default(cuid())
  status       ReviewStatus @default(SCHEDULED)
  scheduledAt  DateTime
  completedAt  DateTime?
  location     String?      // rom/sted for samtalen

  // Sensitive innhold – kun synlig for HR, leder og den ansatte
  agenda       String?      @db.Text
  managerNotes String?      @db.Text  // kun synlig for HR og leder
  sharedNotes  String?      @db.Text  // synlig for alle involverte parter
  goals        String?      @db.Text  // målsettinger etter samtalen

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee   Profile @relation("ReviewEmployee", fields: [employeeId], references: [id])
  employeeId String

  manager   Profile @relation("ReviewManager", fields: [managerId], references: [id])
  managerId String

  createdBy   Profile @relation("ReviewCreator", fields: [createdById], references: [id])
  createdById String

  @@index([employeeId])
  @@index([managerId])
  @@index([status])
  @@index([scheduledAt])
}

// ─── Advarsler / Personalsaker (28C) ─────────────────────────────────────────

enum PersonnelCaseType {
  WARNING              // Skriftlig advarsel
  PERFORMANCE_PLAN     // Oppfølgingsplan/PIP
  TERMINATION_NOTICE   // Varsel om oppsigelse
  SUSPENSION           // Suspensjon
  OTHER
}

enum PersonnelCaseStatus {
  OPEN
  CLOSED
  ARCHIVED
}

model PersonnelCase {
  id     String              @id @default(cuid())
  type   PersonnelCaseType
  status PersonnelCaseStatus @default(OPEN)

  // Sensitive innhold – kun HR/ADMIN og tildelt leder
  summary      String  @db.Text       // kort beskrivelse (ikke synlig for ansatt)
  internalNote String? @db.Text       // intern HR-notat (aldri synlig for ansatt)
  outcomeNote  String? @db.Text       // utfall/konklusjon

  isAcknowledged    Boolean   @default(false)  // ansatt har mottatt/kvittert
  acknowledgedAt    DateTime?
  closedAt          DateTime?

  issuedAt  DateTime  @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  employee   Profile @relation("PersonnelCaseEmployee", fields: [employeeId], references: [id])
  employeeId String

  // Leder som er involvert (kan se saken, men ikke internalNote)
  responsibleManager   Profile? @relation("PersonnelCaseManager", fields: [responsibleManagerId], references: [id])
  responsibleManagerId String?

  createdBy   Profile @relation("PersonnelCaseCreator", fields: [createdById], references: [id])
  createdById String

  auditLogs PersonnelCaseAuditLog[]

  @@index([employeeId])
  @@index([status])
  @@index([type])
}

model PersonnelCaseAuditLog {
  id        String   @id @default(cuid())
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  case   PersonnelCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId String

  actor   Profile @relation("PersonnelCaseActor", fields: [actorId], references: [id])
  actorId String

  @@index([caseId])
}

// ─── Kommentarer på saker (29A) ───────────────────────────────────────────────

enum CommentEntityType {
  INCIDENT
  ACTION
  RISK_ASSESSMENT
}

model Comment {
  id         String            @id @default(cuid())
  entityType CommentEntityType
  entityId   String
  body       String            @db.Text
  isInternal Boolean           @default(false)
  editedAt   DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  author   Profile @relation("CommentAuthor", fields: [authorId], references: [id])
  authorId String

  @@index([entityType, entityId])
  @@index([authorId])
}

// ─── Kontrakter (30A) ─────────────────────────────────────────────────────────

enum ContractType {
  EMPLOYMENT        // Ansettelseskontrakt
  AMENDMENT         // Tillegg/endring
  TERMINATION       // Opphørsavtale
  OTHER
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

model Contract {
  id          String         @id @default(cuid())
  title       String
  type        ContractType
  status      ContractStatus @default(DRAFT)
  startDate   DateTime?
  endDate     DateTime?
  notes       String?        @db.Text

  // Fillagring via Supabase Storage
  fileKey     String?        // storage path (privat bucket)
  fileName    String?
  fileMimeType String?

  sharedWithEmployee Boolean   @default(false)
  sharedAt           DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee   Profile @relation("ContractEmployee", fields: [employeeId], references: [id])
  employeeId String

  createdBy   Profile @relation("ContractCreator", fields: [createdById], references: [id])
  createdById String

  signatureRequests SignatureRequest[]

  @@index([employeeId])
  @@index([status])
  @@index([type])
}

// ─── E-signering (30B) ────────────────────────────────────────────────────────

enum SignatureStatus {
  PENDING
  SIGNED
  REJECTED
  EXPIRED
}

enum SignatureProvider {
  MOCK
}

model SignatureRequest {
  id         String           @id @default(cuid())
  status     SignatureStatus  @default(PENDING)
  provider   SignatureProvider @default(MOCK)
  externalId String?
  signedAt   DateTime?
  expiresAt  DateTime?
  rejectedAt DateTime?
  metadata   Json?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  contractId String

  signer   Profile @relation("SignatureRequestSigner", fields: [signerId], references: [id])
  signerId String

  @@index([contractId])
  @@index([signerId])
  @@index([status])
}

// ─── HMS-runde ────────────────────────────────────────────────────────────────

enum InspectionStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum InspectionAnswer {
  YES
  NO
  PARTIAL
  NA
}

model InspectionTemplate {
  id          String   @id @default(cuid())
  title       String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items   InspectionTemplateItem[]
  records InspectionRecord[]
}

model InspectionTemplateItem {
  id          String  @id @default(cuid())
  question    String
  description String?
  order       Int
  required    Boolean @default(true)

  templateId String
  template   InspectionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  responses InspectionResponse[]

  @@index([templateId])
}

model InspectionRecord {
  id          String           @id @default(cuid())
  title       String
  status      InspectionStatus @default(IN_PROGRESS)
  completedAt DateTime?
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  templateId String
  template   InspectionTemplate @relation(fields: [templateId], references: [id])

  locationId String?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  performedById String
  performedBy   Profile @relation("InspectionPerformedBy", fields: [performedById], references: [id])

  responses InspectionResponse[]

  @@index([performedById])
  @@index([templateId])
  @@index([status])
}

model InspectionResponse {
  id       String           @id @default(cuid())
  answer   InspectionAnswer
  comment  String?
  photoUrl String?

  recordId String
  record   InspectionRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  itemId String
  item   InspectionTemplateItem @relation(fields: [itemId], references: [id])

  @@unique([recordId, itemId])
  @@index([recordId])
}

// ─── Sykefraværsoppfølging ────────────────────────────────────────────────────

model SickLeaveCase {
  id         String              @id @default(cuid())
  startDate  DateTime
  returnDate DateTime?
  totalDays  Int                 @default(0)
  status     SickLeaveCaseStatus @default(ACTIVE)
  notes      String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  employee   Profile @relation("SickLeaveCaseEmployee", fields: [employeeId], references: [id])
  employeeId String

  steps SickLeaveFollowUpStep[]

  @@index([employeeId])
  @@index([status])
  @@index([startDate])
}

model SickLeaveFollowUpStep {
  id          String           @id @default(cuid())
  type        FollowUpStepType
  dueDate     DateTime
  completedAt DateTime?
  notes       String?
  createdAt   DateTime         @default(now())

  case   SickLeaveCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseId String

  completedBy   Profile? @relation("StepCompletedBy", fields: [completedById], references: [id])
  completedById String?

  @@index([caseId])
  @@index([dueDate])
}

// ─── Lønns- og ansettelsesdata ────────────────────────────────────────────────

model EmploymentRecord {
  id                   String     @id @default(cuid())
  effectiveFrom        DateTime
  effectiveTo          DateTime?
  employmentPercentage Float      @default(100)
  salary               Int?
  salaryType           SalaryType @default(MONTHLY)
  jobTitle             String?
  notes                String?
  createdAt            DateTime   @default(now())

  profile   Profile @relation("EmploymentRecordProfile", fields: [profileId], references: [id], onDelete: Cascade)
  profileId String

  createdBy   Profile? @relation("EmploymentRecordCreator", fields: [createdById], references: [id])
  createdById String?

  @@index([profileId])
  @@index([effectiveFrom])
}

// ─── Automatiske varsler (dedup-sporing) ─────────────────────────────────────

model SentAlert {
  id       String    @id @default(cuid())
  type     AlertType
  entityId String
  year     Int
  sentAt   DateTime  @default(now())

  @@unique([type, entityId, year])
  @@index([type])
}

// ─── Kunngjøringer ────────────────────────────────────────────────────────────

model Announcement {
  id           String               @id @default(cuid())
  title        String
  body         String
  target       AnnouncementTarget   @default(ALL)
  departmentId String?
  locationId   String?
  publishedAt  DateTime             @default(now())
  expiresAt    DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  author   Profile @relation("AnnouncementAuthor", fields: [authorId], references: [id])
  authorId String

  @@index([authorId])
  @@index([publishedAt])
  @@index([target])
}

model WebAuthnCredential {
  id           String    @id @default(cuid())
  credentialId String    @unique
  publicKey    Bytes
  counter      BigInt    @default(0)
  deviceType   String?
  backedUp     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId String

  @@index([profileId])
}

// ─── Internkontroll ──────────────────────────────────────────────────────────

enum InternkontrollKategori {
  BRANNVERN
  EL_SIKKERHET
  ARBEIDSMILJO
  KJORETOY
  STOFFKARTOTEK
  ANNET
}

enum InternkontrollStatus {
  OK
  FORFALLER_SNART   // < 30 dager
  FORFALT
  IKKE_SATT
}

model InternkontrollOmrade {
  id            String                    @id @default(cuid())
  kategori      InternkontrollKategori
  tittel        String
  beskrivelse   String?
  intervalDager Int                       // hvor ofte kontroll skal gjøres
  ansvarligId   String?
  locationId    String?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  ansvarlig Profile?               @relation("InternkontrollAnsvarlig", fields: [ansvarligId], references: [id])
  logg      InternkontrollLogg[]

  @@index([kategori])
  @@index([locationId])
}

model InternkontrollLogg {
  id           String   @id @default(cuid())
  omradeId     String
  utfortAvId   String
  utfortDato   DateTime
  nesteFrist   DateTime
  godkjent     Boolean  @default(true)
  merknad      String?
  dokumentUrl  String?
  sjekkpunkter Json?    // strukturerte sjekkliste-resultater for fagmoduler
  createdAt    DateTime @default(now())

  omrade    InternkontrollOmrade @relation(fields: [omradeId], references: [id], onDelete: Cascade)
  utfortAv  Profile              @relation("InternkontrollUtfort", fields: [utfortAvId], references: [id])

  @@index([omradeId])
  @@index([nesteFrist])
}

// ─── Økonomi / Kontrakter (admin-only) ───────────────────────────────────────

enum FinancialContractType {
  RENT
  LEASE
  HUSLEIE
  SERVICE_AGREEMENT
  SUBSCRIPTION
  INSURANCE
  SUPPLIER
  OTHER
}

enum FinancialContractStatus {
  ACTIVE
  EXPIRES_SOON
  EXPIRED
  TERMINATED
  DRAFT
}

model FinancialContract {
  id                  String                        @id @default(cuid())
  name                String
  contractNumber      String?
  type                FinancialContractType
  supplierName        String
  locationId          String?
  centerName          String?
  areaSqm             Float?
  startDate           DateTime?
  endDate             DateTime?
  durationMonths      Int?
  monthlyAmount       Float?
  annualAmount        Float?
  totalValue          Float?
  currency            String                        @default("NOK")
  status              FinancialContractStatus       @default(DRAFT)
  renewalOption       Boolean                       @default(false)
  noticePeriodMonths  Int?
  description         String?                       @db.Text
  notes               String?                       @db.Text
  terminatedAt        DateTime?
  createdByProfileId  String
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt

  location            Location?                     @relation(fields: [locationId], references: [id])
  createdBy           Profile                       @relation("FinancialContractCreatedBy", fields: [createdByProfileId], references: [id])
  attachments         FinancialContractAttachment[]

  @@index([type])
  @@index([status])
  @@index([locationId])
  @@index([createdByProfileId])
  @@index([endDate])
}

model FinancialContractAttachment {
  id                    String            @id @default(cuid())
  financialContractId   String
  documentId            String?
  fileName              String
  filePath              String
  mimeType              String
  sizeBytes             Int
  uploadedByProfileId   String
  createdAt             DateTime          @default(now())

  financialContract     FinancialContract @relation(fields: [financialContractId], references: [id], onDelete: Cascade)
  uploadedBy            Profile           @relation("FinancialContractAttachmentUploadedBy", fields: [uploadedByProfileId], references: [id])

  @@index([financialContractId])
  @@index([uploadedByProfileId])
}

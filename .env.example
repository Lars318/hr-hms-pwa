# ────────────────────────────────────────────────────────────────────────────────
# Variabler merket NEXT_PUBLIC_ er synlige i nettleserkode (klientbunter).
# Alle øvrige variabler er kun tilgjengelig server-side.
# Aldri legg hemmeligheter i NEXT_PUBLIC_-variabler.
# ────────────────────────────────────────────────────────────────────────────────

# ── Supabase (PUBLIC – nødvendig for klient-auth) ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Supabase (SERVER-ONLY – aldri eksponer til klient) ────────────────────────
# Brukes for å generere signerte upload/download-URL-er fra Supabase Storage
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Database (SERVER-ONLY) ────────────────────────────────────────────────────
# Transaction pooler – for vanlige Prisma-spørringer (port 6543 på Supabase)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-north-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Session pooler / direkte – for Prisma migrate (port 5432 på Supabase)
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-north-1.pooler.supabase.com:5432/postgres

# ── App-URL (brukes i e-postlenker og CSP) ────────────────────────────────────
# Lokal: http://localhost:3000   Produksjon: https://ditt-domene.no
APP_URL=http://localhost:3000

# ── E-postvarsler via Resend (SERVER-ONLY) ────────────────────────────────────
# Opprett konto på https://resend.com og generer en API-nøkkel
RESEND_API_KEY=re_your_api_key
# Avsenderadresse – domenet må være verifisert i Resend-dashboardet
EMAIL_FROM=HR/HMS <no-reply@dittdomene.no>
# Sett til "true" for å aktivere faktisk e-postsending (false = kun console.log i dev)
EMAIL_NOTIFICATIONS_ENABLED=false

# ── Web Push / VAPID (SERVER-ONLY unntatt NEXT_PUBLIC_VAPID_PUBLIC_KEY) ───────
# Generer nøkler med: npx web-push generate-vapid-keys
#
# VAPID_PUBLIC_KEY og NEXT_PUBLIC_VAPID_PUBLIC_KEY skal ha SAMME verdi.
# NEXT_PUBLIC_ gjør nøkkelen tilgjengelig i klientkode (trygt – VAPID public key er offentlig).
# VAPID_PRIVATE_KEY er SERVER-ONLY og må aldri eksponeres til klienten.
VAPID_PUBLIC_KEY=din_vapid_public_key
NEXT_PUBLIC_VAPID_PUBLIC_KEY=din_vapid_public_key
VAPID_PRIVATE_KEY=din_vapid_private_key
VAPID_SUBJECT=mailto:admin@dittdomene.no
# Sett til "true" for å aktivere faktisk push-sending (false = kun console.log i dev)
PUSH_NOTIFICATIONS_ENABLED=false

# ── Sentry – feilsporing og ytelsesovervåkning (SERVER-ONLY unntatt NEXT_PUBLIC_) ──
# Opprett prosjekt på https://sentry.io og hent DSN under Settings → Client Keys
# SENTRY_DSN og NEXT_PUBLIC_SENTRY_DSN skal ha SAMME verdi
SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production  # production | staging | development
SENTRY_ENVIRONMENT=production
# Brukes ved kildekartopplasting under bygg (hent under Sentry → Settings → Auth Tokens)
SENTRY_AUTH_TOKEN=sntrys_xxx
SENTRY_ORG=din-sentry-org
SENTRY_PROJECT=hr-hms-pwa

# ── Regelbasert assistent (SERVER-ONLY) ──────────────────────────────────────
# Sett til "false" for å skjule assistentknappen i produksjon
# Standard: aktivert (knappen vises hvis variabelen mangler eller er "true")
ASSISTANT_ENABLED=true

# ── Sikkerhet / konfigurasjon ─────────────────────────────────────────────────
# NODE_ENV settes automatisk av Vercel/Next.js – ikke sett manuelt i produksjon
# NODE_ENV=production
